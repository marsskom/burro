{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["actions"],
  "additionalProperties": false,

  "properties": {
    "actions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "priority", "match", "action"],
        "additionalProperties": false,

        "properties": {
          "id": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[a-zA-Z0-9_.-]+$"
          },

          "priority": {
            "type": "integer",
            "minimum": 0,
            "maximum": 1000
          },

          "on_match": {
            "type": "string",
            "enum": ["stop", "continue"],
            "default": "continue"
          },

          "match": {
            "$ref": "#/definitions/match"
          },

          "action": {
            "type": "array",
            "minItems": 1,
            "items": {
              "$ref": "#/definitions/action"
            }
          }
        }
      }
    }
  },

  "definitions": {
    "match": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "all": {
          "type": "array",
          "items": { "$ref": "#/definitions/match" }
        },

        "any": {
          "type": "array",
          "items": { "$ref": "#/definitions/match" }
        },

        "not": {
          "$ref": "#/definitions/match"
        },

        "method": {
          "type": "string"
        },

        "domain": {
          "type": "string"
        },

        "path": {
          "type": "string"
        },

        "ip": {
          "type": "string"
        },

        "headers": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        }
      }
    },

    "action": {
      "type": "object",
      "required": ["op"],
      "additionalProperties": false,

      "properties": {
        "op": {
          "type": "string",
          "enum": [
            "deny",
            "allow",
            "set_header",
            "remove_header",
            "redact_body",
            "log"
          ]
        },

        "args": {
          "type": "object",
          "additionalProperties": true
        }
      }
    }
  }
}
